# API Configuration
# Base URL for all API endpoints
REACT_APP_API_BASE_URL=http://localhost:4000/api

# OAuth Configuration
# Token endpoint for OAuth client credentials flow
REACT_APP_OAUTH_TOKEN_URL=http://localhost:4000/oauth/token

# OAuth client ID - identifies this application to the authorization server
REACT_APP_OAUTH_CLIENT_ID=bms-demo-client

# OAuth client secret - authenticates this application (keep secure in production)
REACT_APP_OAUTH_CLIENT_SECRET=bms-demo-secret

# OAuth grant type - client_credentials for service-to-service authentication
REACT_APP_OAUTH_GRANT_TYPE=client_credentials

# OAuth scopes - space-separated list of required permissions
REACT_APP_OAUTH_SCOPE=quote:read quote:write
