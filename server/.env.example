# ─────────────────────────────────────────────────────────────
#  BMS Server Environment Variables
#  Copy this file to .env and fill in the values for your
#  environment (or set them in Azure Web App → Configuration).
# ─────────────────────────────────────────────────────────────

# Server mode: "mock" for local dev, "proxy" for real API calls
SERVER_MODE=mock

# Port the Express server listens on (Azure overrides this automatically)
PORT=4000

# ── AWS API (proxy mode only) ────────────────────────────────
# Base URL of the upstream API gateway
AWS_API_BASE_URL=https://your-api-id.execute-api.region.amazonaws.com/stage

# Paths appended to the base URL
AWS_QUOTE_PATH=/quote
AWS_BIND_PATH=/bind

# ── OAuth2 Client Credentials (proxy mode only) ─────────────
# Token endpoint (e.g. Cognito, Auth0, etc.)
OAUTH_TOKEN_URL=https://your-domain.auth.region.amazoncognito.com/oauth2/token

OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_SCOPE=quote:read quote:write
